#!/usr/bin/env ruby
# frozen_string_literal: true

# Same as bin/parallel_rspec but reads `.parallel_rspec_config.local` (does not
# copy over `.parallel_rspec_config`).

require "bundler/setup"

ENV["PARALLEL_RSPEC_CONFIG"] = File.expand_path("../.parallel_rspec_config.local", __dir__)
load File.expand_path("parallel_rspec", __dir__)
