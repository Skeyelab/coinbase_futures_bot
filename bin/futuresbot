#!/usr/bin/env ruby
# frozen_string_literal: true

# bin/futuresbot – Thor-based CLI entry point for the Coinbase Futures Bot.
#
# Usage:
#   bin/futuresbot help
#   bin/futuresbot chat
#   bin/futuresbot chat --resume
#   bin/futuresbot status
#   bin/futuresbot positions
#   bin/futuresbot signals
#
# On `dashboard` (default) and `chat`, positions are synced from Coinbase first.
# Set FUTURESBOT_SKIP_POSITION_SYNC=1 to skip (e.g. CI or offline use).

APP_PATH = File.expand_path("../config/application", __dir__)
require_relative "../config/boot"
require_relative "../config/environment"
require_relative "../lib/cli/futures_bot_cli"

FuturesBotCli.start(ARGV)
