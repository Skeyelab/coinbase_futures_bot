# Coinbase Futures Bot - Environment Variables Configuration
# Copy this file to .env and fill in your actual values
# The .env file is gitignored and should never be committed

# ===================================
# Database Configuration (Required)
# ===================================
DATABASE_URL=postgresql://username:password@localhost:5432/coinbase_futures_bot_development

# ===================================
# Coinbase API Configuration (Required)
# ===================================
# Get your API credentials from: https://www.coinbase.com/settings/api
COINBASE_API_KEY=your_coinbase_api_key_here
COINBASE_API_SECRET=your_coinbase_api_secret_here

# ===================================
# AI Service Configuration (Required for Chat Bot)
# ===================================
# OpenRouter API (Primary AI provider)
# Get your API key from: https://openrouter.ai/
OPENROUTER_API_KEY=your_openrouter_api_key_here

# OpenAI API (Fallback AI provider)
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your_openai_api_key_here

# ===================================
# News & Sentiment Analysis (Required)
# ===================================
# CryptoPanic API for news sentiment
# Get your token from: https://cryptopanic.com/developers/api/
CRYPTOPANIC_TOKEN=your_cryptopanic_token_here

# ===================================
# Feature Flags
# ===================================
# Enable sentiment analysis filtering in trading strategies
SENTIMENT_ENABLE=true

# Z-score threshold for sentiment filtering (default: 1.2)
SENTIMENT_Z_THRESHOLD=1.2

# Enable paper trading mode (simulated trades, no real money)
PAPER_TRADING_MODE=true

# ===================================
# Trading Configuration
# ===================================
# Default equity for signal generation (USD)
SIGNAL_EQUITY_USD=10000

# Paper trading equity (USD)
PAPER_EQUITY_USD=10000

# Position sizing limits
MAX_POSITION_SIZE=5
MIN_POSITION_SIZE=1

# Basis threshold in basis points
BASIS_THRESHOLD_BPS=50

# ===================================
# Error Monitoring (Optional - Recommended for Production)
# ===================================
# Sentry DSN for error tracking
# Get your DSN from: https://sentry.io/
# SENTRY_DSN=your_sentry_dsn_here
# SENTRY_ENVIRONMENT=development
# SENTRY_TRACES_SAMPLE_RATE=0.1
# SENTRY_PROFILES_SAMPLE_RATE=0.1

# Performance thresholds (milliseconds)
# SENTRY_SLOW_QUERY_THRESHOLD=1000
# SENTRY_SLOW_API_THRESHOLD=5000
# SENTRY_SLOW_TRADING_THRESHOLD=10000
# SENTRY_HIGH_MEMORY_THRESHOLD=1000

# ===================================
# Slack Integration (Optional)
# ===================================
# Enable Slack notifications
# SLACK_ENABLED=false
# SLACK_BOT_TOKEN=xoxb-your-bot-token
# SLACK_ALERTS_CHANNEL=#alerts
# SLACK_POSITIONS_CHANNEL=#positions
# SLACK_DAY_TRADING_CHANNEL=#day-trading
# SLACK_MARGIN_ALERTS_CHANNEL=#margin-alerts
# SLACK_RISK_ALERTS_CHANNEL=#risk-alerts
# SLACK_AUTHORIZED_USERS=U123456,U789012

# ===================================
# API Authentication (Optional)
# ===================================
# HTTP Basic Auth for API endpoints
# POSITIONS_AUTH_USER=admin
# POSITIONS_AUTH_PASS=secure_password
# SIGNALS_API_KEY=your_api_key

# ===================================
# Job Scheduling (Optional - Override Defaults)
# ===================================
# Cron expressions for background jobs
# CANDLES_CRON="0 5 * * *"              # Fetch candles hourly at minute 5
# SENTIMENT_FETCH_CRON="*/2 * * * *"    # Fetch news every 2 minutes
# SENTIMENT_SCORE_CRON="*/2 * * * *"    # Score sentiment every 2 minutes
# SENTIMENT_AGG_CRON="*/5 * * * *"      # Aggregate sentiment every 5 minutes
# PAPER_CRON="*/15 * * * *"             # Paper trading every 15 minutes
# CALIBRATE_CRON="0 2 * * *"            # Strategy calibration daily at 2 AM UTC

# ===================================
# GoodJob Configuration (Optional)
# ===================================
# Worker configuration
# GOOD_JOB_EXECUTION_MODE=async         # async|external|inline
# GOOD_JOB_MAX_THREADS=5                # Number of worker threads
# GOOD_JOB_POLL_INTERVAL=10             # Seconds between job polls
# GOOD_JOB_CLEANUP_INTERVAL=1           # Days to keep job records

# ===================================
# Rails Environment (Optional)
# ===================================
# RAILS_ENV=development                 # development|test|production
# RAILS_LOG_LEVEL=debug                 # debug|info|warn|error|fatal
# RAILS_MAX_THREADS=5                   # Max threads per worker
# PORT=3000                             # Server port
# WEB_CONCURRENCY=1                     # Number of worker processes

# ===================================
# WebSocket URLs (Optional - Override Defaults)
# ===================================
# COINBASE_FUTURES_WS_URL=wss://advanced-trade-ws.coinbase.com
# COINBASE_SPOT_WS_URL=wss://ws-feed.exchange.coinbase.com

# ===================================
# API URLs (Optional - Override Defaults)
# ===================================
# COINBASE_AT_REST_URL=https://api.coinbase.com
# COINBASE_EXCHANGE_REST_URL=https://api.exchange.coinbase.com
# CRYPTOPANIC_BASE_URL=https://cryptopanic.com/api/v1
# COINDESK_RSS_URL=https://www.coindesk.com/arc/outboundfeeds/rss/
# COINTELEGRAPH_RSS_URL=https://cointelegraph.com/rss

# ===================================
# Development & Debug (Optional)
# ===================================
# Enable debug logging
# DEBUG=true

# Run jobs inline for debugging
# INLINE=1

# Disable rate limiting for development
# DISABLE_RATE_LIMITING=true

# Mock external APIs for offline development
# MOCK_COINBASE_API=false

# ===================================
# Production-Only (Required in Production)
# ===================================
# SECRET_KEY_BASE=generate_with_rails_secret
# FORCE_SSL=true
# APP_VERSION=1.0.0
