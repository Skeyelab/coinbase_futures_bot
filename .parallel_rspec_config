# Options for `bin/parallel_rspec` (wired to parallel_tests CLI — not read by the gem alone).
# Omit `processes` to use parallel_tests default (CPU count or PARALLEL_TEST_PROCESSORS).

# Heavy specs in one worker to reduce tail latency (each line is a -s regex fragment).
single:
  - "spec/services/coinbase_rest_spec.rb"
  - "spec/models/trading_pair_spec.rb"
  - "spec/tasks/market_data_rake_spec.rb"

# Applied only when tmp/parallel_runtime_rspec.log exists (see bin/parallel_rspec).
group_by: runtime
