<style>
  /* ===== Design tokens ===== */
  :root {
    color-scheme: light dark;

    --font-ui: system-ui, -apple-system, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
    --font-mono: ui-monospace, "SF Mono", Menlo, Consolas, "Liberation Mono", monospace;

    --text-xs: 0.75rem;
    --text-sm: 0.8125rem;
    --text-base: 0.875rem;
    --text-lg: 1rem;
    --text-xl: 1.25rem;

    --sp-1: 0.25rem;
    --sp-2: 0.5rem;
    --sp-3: 0.75rem;
    --sp-4: 1rem;
    --sp-6: 1.5rem;
    --sp-8: 2rem;

    --radius-sm: 4px;
    --radius-md: 6px;

    --surface: #f6f8fa;
    --surface-raised: #ffffff;
    --border: #d0d7de;
    --border-strong: #8c959f;
    --text: #1f2328;
    --text-muted: #59636e;
    --accent: #0969da;
    --accent-hover: #0757ba;
    --green: #1a7f37;
    --red: #cf222e;
    --amber: #9a6700;
    --green-bg: #dafbe1;
    --red-bg: #ffebe9;
    --amber-bg: #fff8c5;
    --banner-paper-bg: #f5c518;
    --banner-paper-fg: #241a00;
    --banner-live-bg: #c50f1f;
    --banner-live-fg: #ffffff;
    --shadow: 0 1px 2px rgb(31 35 40 / 0.06);
  }

  /* ===== Base ===== */
  * { box-sizing: border-box; }

  body {
    margin: 0;
    background: var(--surface);
    color: var(--text);
    font: var(--text-base)/1.5 var(--font-ui);
  }

  :focus-visible { outline: 2px solid var(--accent); outline-offset: 2px; }

  a { color: var(--accent); }

  h2 { font-size: var(--text-xl); font-weight: 650; margin: var(--sp-4) 0 var(--sp-3); }
  h3 { font-size: var(--text-lg); font-weight: 600; margin: var(--sp-6) 0 var(--sp-2); }

  small { font-size: var(--text-xs); color: var(--text-muted); }

  main { padding-bottom: var(--sp-8); }

  .wrap { max-width: 72rem; margin: 0 auto; padding: 0 var(--sp-4); }

  .muted { color: var(--text-muted); }

  .mono { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }

  /* ===== Site header ===== */
  .site-header { background: var(--surface-raised); border-bottom: 1px solid var(--border); }
  .site-header h1 { font-size: var(--text-xl); font-weight: 650; margin: 0; padding: var(--sp-4) 0; }
  .site-header a { color: inherit; text-decoration: none; }
  .site-header a:hover { text-decoration: underline; }

  /* ===== Mode banner (safety surface) ===== */
  .banner {
    position: sticky;
    top: 0;
    z-index: 100;
    display: flex;
    align-items: center;
    gap: var(--sp-3);
    padding: var(--sp-2) var(--sp-4);
    font-weight: 600;
    font-size: var(--text-sm);
  }
  .banner-tag {
    font-family: var(--font-mono);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    border: 2px solid currentColor;
    border-radius: var(--radius-sm);
    padding: 0 var(--sp-2);
    font-weight: 700;
    white-space: nowrap;
  }
  .banner--paper { background: var(--banner-paper-bg); color: var(--banner-paper-fg); }
  .banner--live { background: var(--banner-live-bg); color: var(--banner-live-fg); border-bottom: 3px solid var(--red); }

  /* ===== Flash notice / error ===== */
  .flash {
    padding: var(--sp-3) var(--sp-4);
    border: 1px solid;
    border-left-width: 4px;
    border-radius: var(--radius-md);
    margin: var(--sp-4) 0;
    font-size: var(--text-sm);
  }
  .flash--notice { border-color: var(--green); background: var(--green-bg); color: var(--text); }
  .flash--error { border-color: var(--red); background: var(--red-bg); color: var(--text); }
  .flash small { display: block; margin-top: var(--sp-1); }

  /* ===== Card / panel ===== */
  .card {
    background: var(--surface-raised);
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    padding: var(--sp-4);
    margin: var(--sp-4) 0 var(--sp-6);
    box-shadow: var(--shadow);
  }
  .card--danger { border-color: var(--red); }
  .card--success { border-color: var(--green); }
  .card-title { margin: 0 0 var(--sp-3); font-size: var(--text-lg); font-weight: 600; }
  .card p:first-child { margin-top: 0; }
  .card p:last-child { margin-bottom: 0; }
  .form-card { max-width: 32rem; }

  /* ===== Details list (edit page) ===== */
  .details { display: grid; grid-template-columns: max-content 1fr; gap: var(--sp-2) var(--sp-4); margin: 0; }
  .details dt { font-weight: 600; font-size: var(--text-sm); color: var(--text-muted); }
  .details dd { margin: 0; }

  /* ===== Data table ===== */
  .table-wrap {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    border: 1px solid var(--border);
    border-radius: var(--radius-md);
    background: var(--surface-raised);
  }
  .positions-table { width: 100%; min-width: 720px; border-collapse: collapse; font-size: var(--text-base); }
  .positions-table th {
    text-align: left;
    font-size: var(--text-xs);
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--text-muted);
    padding: var(--sp-2) var(--sp-3);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    white-space: nowrap;
  }
  .positions-table td { padding: var(--sp-2) var(--sp-3); border-bottom: 1px solid var(--border); }
  .positions-table tbody tr:last-child td { border-bottom: none; }
  .positions-table tbody tr:hover { background: color-mix(in srgb, var(--accent) 6%, transparent); }
  .positions-table th:last-child, .positions-table td:last-child { text-align: right; }
  th.num, td.num { text-align: right; font-family: var(--font-mono); font-variant-numeric: tabular-nums; }

  /* ===== Buttons ===== */
  .btn {
    display: inline-flex;
    align-items: center;
    gap: var(--sp-1);
    padding: var(--sp-2) var(--sp-3);
    font: 600 var(--text-sm)/1.2 var(--font-ui);
    border-radius: var(--radius-sm);
    border: 1px solid transparent;
    cursor: pointer;
    text-decoration: none;
    transition: background 120ms ease, border-color 120ms ease;
  }
  .btn:disabled { opacity: 0.55; pointer-events: none; }
  .btn--primary { background: var(--accent); color: #fff; }
  .btn--primary:hover { background: var(--accent-hover); }
  .btn--secondary { background: var(--surface-raised); color: var(--text); border-color: var(--border); }
  .btn--secondary:hover { border-color: var(--border-strong); }
  .btn--danger { background: var(--red); color: #fff; }
  .btn--danger:hover { background: color-mix(in srgb, var(--red) 88%, #000); }
  .btn--success { background: var(--green); color: #fff; }
  .btn--success:hover { background: color-mix(in srgb, var(--green) 88%, #000); }
  .btn--lg { padding: var(--sp-3) var(--sp-6); font-size: var(--text-base); }

  /* ===== Forms ===== */
  label { display: block; margin-bottom: var(--sp-1); font-size: var(--text-sm); font-weight: 600; color: var(--text); }
  input[type="text"], input[type="number"], select {
    padding: var(--sp-2) var(--sp-3);
    background: var(--surface-raised);
    color: var(--text);
    border: 1px solid var(--border);
    border-radius: var(--radius-sm);
    font-size: var(--text-base);
    font-family: var(--font-ui);
  }
  input[type="number"] { font-family: var(--font-mono); font-variant-numeric: tabular-nums; }
  input:focus, select:focus {
    border-color: var(--accent);
    outline: 2px solid color-mix(in srgb, var(--accent) 35%, transparent);
    outline-offset: 0;
  }
  .field { margin-bottom: var(--sp-4); }
  .field input, .field select { width: 100%; }
  .field small { display: block; margin-top: var(--sp-1); }
  .field-hint { display: block; margin-top: var(--sp-3); font-size: var(--text-xs); color: var(--text-muted); }
  .card form { max-width: 26rem; }
  form.form-grid, .form-card form { max-width: none; }
  .form-grid { display: flex; flex-wrap: wrap; gap: var(--sp-3); align-items: flex-end; }
  .form-grid .field { margin-bottom: 0; }
  .form-grid .field input, .form-grid .field select { width: auto; }

  /* ===== Side badge (LONG / SHORT) ===== */
  .side--long, .side--short {
    display: inline-block;
    font: 700 var(--text-xs)/1.6 var(--font-mono);
    letter-spacing: 0.06em;
    padding: 0 var(--sp-2);
    border-radius: var(--radius-sm);
    border: 1px solid;
  }
  .side--long { color: var(--green); background: var(--green-bg); border-color: color-mix(in srgb, var(--green) 40%, transparent); }
  .side--short { color: var(--red); background: var(--red-bg); border-color: color-mix(in srgb, var(--red) 40%, transparent); }

  /* ===== PnL value ===== */
  .pnl--pos, .pnl--neg { font-family: var(--font-mono); font-variant-numeric: tabular-nums; font-weight: 600; }
  .pnl--pos { color: var(--green); }
  .pnl--neg { color: var(--red); }

  /* ===== Empty state ===== */
  .empty {
    border: 1px dashed var(--border);
    border-radius: var(--radius-md);
    padding: var(--sp-8) var(--sp-4);
    text-align: center;
    color: var(--text-muted);
    margin: var(--sp-4) 0;
  }
  .empty p { margin: 0 0 var(--sp-1); }
  .empty p:last-child { margin-bottom: 0; }

  /* ===== Dark theme token swap ===== */
  @media (prefers-color-scheme: dark) {
    :root {
      --surface: #0d1117;
      --surface-raised: #161b22;
      --border: #30363d;
      --border-strong: #6e7681;
      --text: #e6edf3;
      --text-muted: #9198a1;
      --accent: #4493f8;
      --accent-hover: #5ea1f9;
      --green: #3fb950;
      --red: #f85149;
      --amber: #d29922;
      --green-bg: rgb(63 185 80 / 0.14);
      --red-bg: rgb(248 81 73 / 0.14);
      --amber-bg: rgb(210 153 34 / 0.14);
      --banner-paper-bg: #b8860b;
      --banner-paper-fg: #0d1117;
      --banner-live-bg: #da3633;
      --banner-live-fg: #ffffff;
      --shadow: none;
    }
  }

  /* ===== Narrow screens ===== */
  @media (max-width: 640px) {
    .form-grid { flex-direction: column; align-items: stretch; }
    .form-grid .field { margin-bottom: 0; }
    .form-grid .field input, .form-grid .field select { width: 100%; }
    .card form .btn { width: 100%; justify-content: center; }
    .positions-table th, .positions-table td { padding: var(--sp-1) var(--sp-2); }
  }
</style>
