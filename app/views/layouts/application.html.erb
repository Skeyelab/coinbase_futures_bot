<!DOCTYPE html>
<html>
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="color-scheme" content="light dark" />
  <title>Positions</title>
  <%= render "layouts/styles" %>
</head>
<body>
  <header class="site-header">
    <div class="wrap">
      <h1><a href="/positions">Open Positions</a></h1>
    </div>
  </header>

  <main>
    <% if @notice_message.present? %>
      <div class="wrap">
        <div class="flash flash--notice" role="status"><%= @notice_message %></div>
      </div>
    <% end %>
    <% if @error_message.present? %>
      <div class="wrap">
        <div class="flash flash--error" role="alert"><%= @error_message %></div>
      </div>
    <% end %>

    <%= yield %>
  </main>
</body>
</html>
