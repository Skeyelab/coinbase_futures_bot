<div>
  <p>
    <strong>Product:</strong> <%= @position["product_id"] %><br/>
    <strong>Current side:</strong> <%= (@position["side"] || @position["position_side"] || @position.dig("position", "side") || "") %><br/>
    <strong>Current size:</strong> <%= (@position["size"] || @position["base_size"] || @position["quantity"] || @position.dig("position", "size") || "") %>
  </p>

  <h3>Close position</h3>
  <p>Submit a market order in the opposite direction to close fully or partially.</p>
  <form action="<%= position_path(@position["product_id"]) %>" method="post" style="display: inline-block;">
    <input type="hidden" name="_method" value="patch" />
    <label for="size">Size to close (leave blank to close inferred open size):</label>
    <input id="size" name="size" type="text" placeholder="e.g. 0.01" />
    <button type="submit">Submit Close</button>
  </form>

  <p style="margin-top: 1rem;">
    <a class="button secondary" href="<%= positions_path %>">Back</a>
  </p>
</div>