<div>
  <h2>Position Details</h2>
  <div style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
    <p>
      <strong>Product:</strong> <%= @position["product_id"] %><br/>
      <strong>Side:</strong>
      <span style="color: <%= @position["side"] == 'LONG' ? '#28a745' : '#dc3545' %>; font-weight: bold;">
        <%= (@position["side"] || @position["position_side"] || @position.dig("position", "side") || "") %>
      </span><br/>
      <strong>Size:</strong> <%= (@position["number_of_contracts"] || @position["size"] || @position["base_size"] || @position["quantity"] || @position.dig("position", "size") || "") %> contracts<br/>
      <strong>Current Price:</strong> <%= @position["current_price"] || "N/A" %><br/>
      <strong>Entry Price:</strong> <%= @position["avg_entry_price"] || "N/A" %><br/>
      <strong>Unrealized P&L:</strong>
      <% if @position["unrealized_pnl"] %>
        <span style="color: <%= @position["unrealized_pnl"].to_f >= 0 ? '#28a745' : '#dc3545' %>; font-weight: bold;">
          <%= @position["unrealized_pnl"] %>
        </span>
      <% else %>
        N/A
      <% end %>
    </p>
  </div>

  <h3>Increase Position</h3>
  <p>Add more contracts to your existing position. This will execute a market order in the same direction.</p>
  <form action="<%= increase_position_path(@position["product_id"]) %>" method="post" style="display: inline-block; margin-bottom: 20px; border: 2px solid #28a745; padding: 15px; border-radius: 8px;">
    <label for="increase_size">Additional contracts to add:</label>
    <input id="increase_size" name="size" type="number" step="0.01" min="0.01" required
           placeholder="e.g. 1" style="padding: 8px; margin: 8px 0; border: 1px solid #ccc; border-radius: 4px; width: 200px;" />
    <button type="submit" style="padding: 8px 16px; background: #28a745; color: white; border: none; border-radius: 4px; cursor: pointer;">Increase Position</button>
  </form>

  <p style="margin-bottom: 20px;">
    <small style="color: #666;">
      <strong>Need to open a different position?</strong>
      <a href="<%= new_position_path %>" style="color: #007bff;">Open new position</a> or
      <a href="<%= positions_path %>" style="color: #007bff;">view all positions</a>.
    </small>
  </p>

  <h3>Close Position</h3>
  <p>Submit a market order in the opposite direction to close fully or partially.</p>
  <form action="<%= close_position_path(@position["product_id"]) %>" method="post" style="display: inline-block; border: 2px solid #dc3545; padding: 15px; border-radius: 8px;">
    <label for="size">Size to close (leave blank to close all <%= (@position["number_of_contracts"] || @position["size"] || @position["base_size"] || @position["quantity"] || @position.dig("position", "size") || "") %> contracts):</label>
    <input id="size" name="size" type="text" placeholder="e.g. 1" style="padding: 8px; margin: 8px 0; border: 1px solid #ccc; border-radius: 4px; width: 200px;" />
    <button type="submit" style="padding: 8px 16px; background: #dc3545; color: white; border: none; border-radius: 4px; cursor: pointer;">Submit Close</button>
  </form>

  <p style="margin-top: 1rem;">
    <a class="button secondary" href="<%= positions_path %>">← Back to Positions</a>
  </p>
</div>

<script>
  // Add debugging to see which form is being submitted
  document.addEventListener('DOMContentLoaded', function() {
    // Increase form
    const increaseForm = document.querySelector('form[action*="increase"]');
    if (increaseForm) {
      increaseForm.addEventListener('submit', function(e) {
        console.log('INCREASE FORM SUBMITTED');
        console.log('Form action:', this.action);
        console.log('Form data:', new FormData(this));
      });
    }

    // Close form
    const closeForm = document.querySelector('form[action*="close"]');
    if (closeForm) {
      closeForm.addEventListener('submit', function(e) {
        console.log('CLOSE FORM SUBMITTED');
        console.log('Form action:', this.action);
        console.log('Form data:', new FormData(this));
      });
    }
  });
</script>
