<div class="wrap">
  <h2>Position Details</h2>
  <section class="card">
    <dl class="details">
      <dt>Product:</dt>
      <dd><span class="mono"><%= @position["product_id"] %></span></dd>

      <dt>Side:</dt>
      <dd>
        <span class="<%= @position["side"] == 'LONG' ? 'side--long' : 'side--short' %>">
          <%= (@position["side"] || @position["position_side"] || @position.dig("position", "side") || "") %>
        </span>
      </dd>

      <dt>Size:</dt>
      <dd><span class="mono"><%= (@position["number_of_contracts"] || @position["size"] || @position["base_size"] || @position["quantity"] || @position.dig("position", "size") || "") %></span> contracts</dd>

      <dt>Current Price:</dt>
      <dd><span class="mono"><%= @position["current_price"] || "N/A" %></span></dd>

      <dt>Entry Price:</dt>
      <dd><span class="mono"><%= @position["avg_entry_price"] || "N/A" %></span></dd>

      <dt>Unrealized P&L:</dt>
      <dd>
        <% if @position["unrealized_pnl"] %>
          <span class="<%= @position["unrealized_pnl"].to_f >= 0 ? 'pnl--pos' : 'pnl--neg' %>">
            <%= @position["unrealized_pnl"] %>
          </span>
        <% else %>
          <span class="muted">N/A</span>
        <% end %>
      </dd>
    </dl>
  </section>

  <section class="card card--success">
    <h3 class="card-title">Increase Position</h3>
    <p class="muted">Add more contracts to your existing position. This will execute a market order in the same direction.</p>
    <form action="<%= increase_position_path(@position["product_id"]) %>" method="post">
      <div class="field">
        <label for="increase_size">Additional contracts to add:</label>
        <input id="increase_size" name="size" type="number" step="0.01" min="0.01" required placeholder="e.g. 1" />
      </div>
      <button type="submit" class="btn btn--success">Increase Position</button>
    </form>
  </section>

  <p class="field-hint">
    <strong>Need to open a different position?</strong>
    <a href="<%= new_position_path %>">Open new position</a> or
    <a href="<%= positions_path %>">view all positions</a>.
  </p>

  <section class="card card--danger">
    <h3 class="card-title">Close Position</h3>
    <p class="muted">Submit a market order in the opposite direction to close fully or partially.</p>
    <form action="<%= close_position_path(@position["product_id"]) %>" method="post">
      <div class="field">
        <label for="size">Size to close (leave blank to close all <%= (@position["number_of_contracts"] || @position["size"] || @position["base_size"] || @position["quantity"] || @position.dig("position", "size") || "") %> contracts):</label>
        <input id="size" name="size" type="text" placeholder="e.g. 1" />
      </div>
      <button type="submit" class="btn btn--danger">Submit Close</button>
    </form>
  </section>

  <p>
    <a class="btn btn--secondary" href="<%= positions_path %>">← Back to Positions</a>
  </p>
</div>
