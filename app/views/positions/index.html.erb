<% if @notice_message.present? %>
  <div style="padding: 8px; margin-bottom: 10px; background: #eef7ff; border: 1px solid #b6daff; color: #084b83;">
    <%= @notice_message %>
  </div>
<% end %>

<% if @error_message.present? %>
  <div style="padding: 8px; margin-bottom: 10px; background: #fff4f4; border: 1px solid #ffd3d3; color: #8a1f1f;">
    <strong>Error:</strong> <%= @error_message %><br/>
    <small>
      Tip: Ensure the `cdp_api_key.json` file is present and contains valid API credentials. Check the server logs for authentication details.
    </small>
  </div>
<% end %>

<div style="background: #f8f9fa; padding: 20px; border-radius: 8px; margin-bottom: 20px;">
  <h3 style="margin-top: 0;">Open New Position</h3>
  <form action="<%= positions_path %>" method="post" class="flex gap-2 items-end flex-wrap">
    <div>
      <label for="product_id" style="display: block; margin-bottom: 5px; font-weight: bold; font-size: 14px;">Product:</label>
      <input id="product_id" name="product_id" type="text" required placeholder="e.g. BTC-USD-PERP"
             style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; width: 150px;" />
    </div>

    <div>
      <label for="side" style="display: block; margin-bottom: 5px; font-weight: bold; font-size: 14px;">Side:</label>
      <select id="side" name="side" required style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; width: 100px;">
        <option value="">Side...</option>
        <option value="long">LONG</option>
        <option value="short">SHORT</option>
      </select>
    </div>

    <div>
      <label for="size" style="display: block; margin-bottom: 5px; font-weight: bold; font-size: 14px;">Size:</label>
      <input id="size" name="size" type="number" step="0.01" min="0.01" required placeholder="1.0"
             style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; width: 80px;" />
    </div>

    <div>
      <label for="order_type" style="display: block; margin-bottom: 5px; font-weight: bold; font-size: 14px;">Type:</label>
      <select id="order_type" name="order_type" required style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; width: 100px;">
        <option value="market">Market</option>
        <option value="limit">Limit</option>
      </select>
    </div>

    <div id="quick_price_field" style="display: none;">
      <label for="price" style="display: block; margin-bottom: 5px; font-weight: bold; font-size: 14px;">Price:</label>
      <input id="price" name="price" type="number" step="0.01" min="0.01" placeholder="50000"
             style="padding: 8px; border: 1px solid #ccc; border-radius: 4px; width: 100px;" />
    </div>

    <button type="submit">Open Position</button>
  </form>

  <div style="margin-top: 10px;">
    <small style="color: #666;">
      <strong>Quick Open:</strong> Fill out the form above to open a new futures position.
      <a href="<%= new_position_path %>" style="color: #007bff;">Advanced options</a> available.
    </small>
  </div>
</div>

<% if @positions.empty? %>
  <p>No open positions.</p>
<% else %>
  <table style="width: 100%; border-collapse: collapse; margin-top: 20px;">
    <thead>
      <tr style="background: #f8f9fa; border-bottom: 2px solid #dee2e6;">
        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #dee2e6;">Product</th>
        <th style="padding: 12px; text-align: left; border-bottom: 1px solid #dee2e6;">Side</th>
        <th style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">Size</th>
        <th style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">Current Price</th>
        <th style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">Entry Price</th>
        <th style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">Unrealized P&L</th>
        <th style="padding: 12px; text-align: center; border-bottom: 1px solid #dee2e6;">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @positions.each do |p| %>
        <tr style="border-bottom: 1px solid #dee2e6;">
          <td style="padding: 12px; border-bottom: 1px solid #dee2e6;"><%= p["product_id"] %></td>
          <td style="padding: 12px; border-bottom: 1px solid #dee2e6;">
            <span style="color: <%= p["side"] == 'LONG' ? '#28a745' : '#dc3545' %>; font-weight: bold;">
              <%= (p["side"] || p["position_side"] || p.dig("position", "side") || "") %>
            </span>
          </td>
          <td style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">
            <%= (p["number_of_contracts"] || p["size"] || p["base_size"] || p["quantity"] || p.dig("position", "size") || "") %>
          </td>
          <td style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">
            <%= p["current_price"] ? "#{p["current_price"]}" : "" %>
          </td>
          <td style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">
            <%= p["avg_entry_price"] ? "#{p["avg_entry_price"]}" : "" %>
          </td>
          <td style="padding: 12px; text-align: right; border-bottom: 1px solid #dee2e6;">
            <% if p["unrealized_pnl"] %>
              <span style="color: <%= p["unrealized_pnl"].to_f >= 0 ? '#28a745' : '#dc3545' %>; font-weight: bold;">
                <%= p["unrealized_pnl"] %>
              </span>
            <% end %>
          </td>
          <td style="padding: 12px; text-align: center; border-bottom: 1px solid #dee2e6;">
            <a class="button" href="<%= edit_position_path(p["product_id"]) %>">Edit</a>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% end %>

<script>
  // Handle price field visibility for limit orders in quick open form
  document.getElementById('order_type').addEventListener('change', function() {
    const priceField = document.getElementById('quick_price_field');
    const priceInput = document.getElementById('price');

    if (this.value === 'limit') {
      priceField.style.display = 'block';
      priceInput.required = true;
    } else {
      priceField.style.display = 'none';
      priceInput.required = false;
      priceInput.value = '';
    }
  });
</script>
