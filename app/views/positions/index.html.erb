<% if @dry_run %>
  <div class="banner banner--paper" role="status">
    <span class="banner-tag">DRY-RUN (PAPER)</span>
    <span>&mdash; showing simulated paper positions. Your real Coinbase account is not shown here and is not being traded.</span>
  </div>
<% else %>
  <div class="banner banner--live" role="alert">
    <span class="banner-tag">LIVE</span>
    <span>&mdash; showing your real Coinbase account positions.</span>
  </div>
<% end %>

<div class="wrap">
  <% if @notice_message.present? %>
    <div class="flash flash--notice" role="status"><%= @notice_message %></div>
  <% end %>

  <% if @error_message.present? %>
    <div class="flash flash--error" role="alert">
      <strong>Error:</strong> <%= @error_message %><br/>
      <small>
        Tip: Ensure the `cdp_api_key.json` file is present and contains valid API credentials. Check the server logs for authentication details.
      </small>
    </div>
  <% end %>

  <section class="card">
    <h3 class="card-title">Open New Position</h3>
    <form action="<%= positions_path %>" method="post" class="form-grid">
      <div class="field">
        <label for="product_id">Product:</label>
        <input id="product_id" name="product_id" type="text" required placeholder="e.g. BTC-USD" />
      </div>

      <div class="field">
        <label for="side">Side:</label>
        <select id="side" name="side" required>
          <option value="">Side...</option>
          <option value="long">LONG</option>
          <option value="short">SHORT</option>
        </select>
      </div>

      <div class="field">
        <label for="size">Size:</label>
        <input id="size" name="size" type="number" step="0.01" min="0.01" required placeholder="1.0" />
      </div>

      <div class="field">
        <label for="order_type">Type:</label>
        <select id="order_type" name="order_type" required>
          <option value="market">Market</option>
          <option value="limit">Limit</option>
        </select>
      </div>

      <div class="field" id="quick_price_field" style="display: none;">
        <label for="price">Price:</label>
        <input id="price" name="price" type="number" step="0.01" min="0.01" placeholder="50000" />
      </div>

      <button type="submit" class="btn btn--primary">Open Position</button>
    </form>

    <p class="field-hint">
      <strong>Quick Open:</strong> Fill out the form above to open a new futures position.
      <a href="<%= new_position_path %>">Advanced options</a> available.
    </p>
  </section>

  <% if @positions.empty? %>
    <div class="empty">
      <p>No open positions.</p>
      <p class="muted">Use the form above to open one.</p>
    </div>
  <% else %>
    <div class="table-wrap">
      <table class="positions-table">
        <thead>
          <tr>
            <th scope="col">Product</th>
            <th scope="col">Side</th>
            <th scope="col" class="num">Size</th>
            <th scope="col" class="num">Current Price</th>
            <th scope="col" class="num">Entry Price</th>
            <th scope="col" class="num">Unrealized P&L</th>
            <th scope="col">Actions</th>
          </tr>
        </thead>
        <tbody>
          <% @positions.each do |p| %>
            <tr>
              <td class="mono"><%= p["product_id"] %></td>
              <td>
                <span class="<%= p["side"] == 'LONG' ? 'side--long' : 'side--short' %>">
                  <%= (p["side"] || p["position_side"] || p.dig("position", "side") || "") %>
                </span>
              </td>
              <td class="num">
                <%= (p["number_of_contracts"] || p["size"] || p["base_size"] || p["quantity"] || p.dig("position", "size") || "") %>
              </td>
              <td class="num">
                <%= p["current_price"] ? "#{p["current_price"]}" : "" %>
              </td>
              <td class="num">
                <%= p["avg_entry_price"] ? "#{p["avg_entry_price"]}" : "" %>
              </td>
              <td class="num">
                <% if p["unrealized_pnl"] %>
                  <span class="<%= p["unrealized_pnl"].to_f >= 0 ? 'pnl--pos' : 'pnl--neg' %>">
                    <%= p["unrealized_pnl"] %>
                  </span>
                <% end %>
              </td>
              <td>
                <a class="btn btn--secondary" href="<%= edit_position_path(p["product_id"]) %>">Edit</a>
              </td>
            </tr>
          <% end %>
        </tbody>
      </table>
    </div>
  <% end %>
</div>

<script>
  // Handle price field visibility for limit orders in quick open form
  document.getElementById('order_type').addEventListener('change', function() {
    const priceField = document.getElementById('quick_price_field');
    const priceInput = document.getElementById('price');

    if (this.value === 'limit') {
      priceField.style.display = 'block';
      priceInput.required = true;
    } else {
      priceField.style.display = 'none';
      priceInput.required = false;
      priceInput.value = '';
    }
  });
</script>
