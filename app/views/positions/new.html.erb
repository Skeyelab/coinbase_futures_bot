<div class="wrap">
  <h2>Open New Position</h2>

  <% if params[:notice].present? %>
    <div class="flash flash--error" role="alert"><%= params[:notice] %></div>
  <% end %>

  <section class="card form-card">
    <p>
      <strong>Product:</strong> <span class="mono"><%= @position["product_id"] %></span><br/>
      <small>This will open a new futures position using the specified parameters.</small>
    </p>
  </section>

  <h3>Position Details</h3>
  <section class="card form-card">
    <form action="<%= positions_path %>" method="post">
      <input type="hidden" name="product_id" value="<%= @position["product_id"] %>" />

      <div class="field">
        <label for="side">Side:</label>
        <select id="side" name="side" required>
          <option value="">Select side...</option>
          <option value="long">LONG (Buy)</option>
          <option value="short">SHORT (Sell)</option>
        </select>
        <small>LONG = bullish, SHORT = bearish</small>
      </div>

      <div class="field">
        <label for="size">Size (contracts):</label>
        <input id="size" name="size" type="number" step="0.01" min="0.01" required placeholder="e.g. 1.0" />
        <small>Number of futures contracts to trade</small>
      </div>

      <div class="field">
        <label for="order_type">Order Type:</label>
        <select id="order_type" name="order_type" required>
          <option value="market">Market Order (immediate execution)</option>
          <option value="limit">Limit Order (specify price)</option>
        </select>
      </div>

      <div class="field" id="price_field" style="display: none;">
        <label for="price">Limit Price (USD):</label>
        <input id="price" name="price" type="number" step="0.01" min="0.01" placeholder="e.g. 50000.00" />
        <small>Required for limit orders</small>
      </div>

      <button type="submit" class="btn btn--success btn--lg">Open Position</button>
      <a class="btn btn--secondary btn--lg" href="<%= positions_path %>">Cancel</a>
    </form>
  </section>

  <script>
    document.getElementById('order_type').addEventListener('change', function() {
      const priceField = document.getElementById('price_field');
      const priceInput = document.getElementById('price');

      if (this.value === 'limit') {
        priceField.style.display = 'block';
        priceInput.required = true;
      } else {
        priceField.style.display = 'none';
        priceInput.required = false;
        priceInput.value = '';
      }
    });
  </script>

  <p>
    <a class="btn btn--secondary" href="<%= positions_path %>">← Back to Positions</a>
  </p>
</div>
