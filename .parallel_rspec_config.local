# Parallel RSpec configuration for local development
# Use this for maximum local performance with 8 processes

# Group slow tests together to avoid one process taking too long
single:
  - "spec/services/coinbase_rest_spec.rb"
  - "spec/models/trading_pair_spec.rb"
  - "spec/tasks/market_data_rake_spec.rb"

# Maximum processes for local development
processes: 8

# Use runtime-based grouping for better distribution
group_by: runtime
