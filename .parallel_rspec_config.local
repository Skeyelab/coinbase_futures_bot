# Local overrides — use `bin/parallel_rspec_local` (see bin/parallel_rspec).

single:
  - "spec/services/coinbase_rest_spec.rb"
  - "spec/models/trading_pair_spec.rb"
  - "spec/tasks/market_data_rake_spec.rb"

# Cap/adjust if DB contention hurts wall time; unset to use CPU default.
processes: 8

group_by: runtime
